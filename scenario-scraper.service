[Unit]
Description=Sophos Scenario Scraper
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/scenario-scraper
ExecStart=/opt/scenario-scraper/venv/bin/python3 -m uvicorn server:app --host 0.0.0.0 --port 3001
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
